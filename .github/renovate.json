{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":timezone(America/Los_Angeles)",
    ":semanticCommits"
  ],
  "dependencyDashboardTitle": "Renovate Dashboard",
  "assignees": ["jacaudi"],
  "labels": ["renovate"],
  "suppressNotifications": [
    "prEditedNotification",
    "prIgnoreNotification"
  ],
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "commitMessagePrefix": "chore(deps):",
  "branchPrefix": "renovate/",
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group Kubernetes client libraries (must be updated together)",
      "matchPackageNames": ["/^k8s\\.io//", "sigs.k8s.io/controller-runtime"],
      "groupName": "kubernetes-client-libraries",
      "recreateWhen": "always"
    },
    {
      "description": "Group Ginkgo and Gomega test framework bumps together",
      "matchPackageNames": ["github.com/onsi/ginkgo/v2", "github.com/onsi/gomega"],
      "groupName": "test-libraries",
      "recreateWhen": "always"
    },
    {
      "description": "Group Go toolchain bumps (go.mod directive, golang Docker image, setup-go version)",
      "matchPackageNames": ["go", "golang"],
      "groupName": "go-toolchain",
      "recreateWhen": "always"
    },
    {
      "description": "cloudflared image bumps -> chore(cloudflared) so the operator gets a patch release",
      "matchDepNames": ["cloudflare/cloudflared"],
      "commitMessagePrefix": "chore(cloudflared):",
      "semanticCommitType": "chore",
      "semanticCommitScope": "cloudflared",
      "recreateWhen": "always"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Match go-version inputs to reusable workflows (native github-actions manager only matches direct setup-go usage)",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": ["go-version:\\s*['\"]?(?<currentValue>[0-9.]+)['\"]?"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "CONTROLLER_TOOLS_VERSION \\?= (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "sigs.k8s.io/controller-tools",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "GOLANGCI_LINT_VERSION \\?= (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "github.com/golangci/golangci-lint/v2",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^internal/controller/tunnel/dataplane\\.go$/"
      ],
      "matchStrings": [
        "const DefaultCloudflaredImage = \"docker\\.io/cloudflare/cloudflared:(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "cloudflare/cloudflared",
      "datasourceTemplate": "docker"
    }
  ]
}
